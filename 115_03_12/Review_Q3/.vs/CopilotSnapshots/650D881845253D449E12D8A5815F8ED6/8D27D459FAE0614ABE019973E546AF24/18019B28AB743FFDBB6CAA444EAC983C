        private void panelNumbers_Paint(object sender, PaintEventArgs e)
        {
            var g = e.Graphics;
            using (var pen = new Pen(Color.Red, 2))
            {
                g.DrawRectangle(pen, 0, 0, panelNumbers.Width - 1, panelNumbers.Height - 1);
            }
        }

        // 在 panelResult 上繪製虛線邊框
        private void panelResult_Paint(object sender, PaintEventArgs e)
        {
            var g = e.Graphics;
            using (var pen = new Pen(Color.Black, 1))
            {
                pen.DashStyle = System.Drawing.Drawing2D.DashStyle.Dash;
                g.DrawRectangle(pen, 0, 0, panelResult.Width - 1, panelResult.Height - 1);
            }
